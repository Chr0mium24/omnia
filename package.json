{
  "name": "omnia",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server + Chrome extension — expose all Chrome APIs and CDP to AI agents",
  "bin": {
    "omnia": "./dist/index.js"
  },
  "files": [
    "dist",
    "extension/dist",
    "extension/manifest.json",
    "extension/popup.html",
    "extension/icons"
  ],
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.build.json && node build.mjs",
    "build:server": "tsc -p tsconfig.build.json",
    "build:ext": "node build.mjs",
    "lint": "eslint .",
    "format": "prettier --write '**/*.{ts,js,json,html,css,md}'",
    "format:check": "prettier --check '**/*.{ts,js,json,html,css,md}'",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.299",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "chrome-extension",
    "browser-automation",
    "cdp",
    "ai-agent"
  ],
  "license": "MIT"
}
